[Unit]
Description=Generate edge search meta report
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/srv/automation-mvp
EnvironmentFile=-/srv/automation-mvp/ops/systemd/edge-search.env
ExecStart=/srv/automation-mvp/.venv/bin/python meta_search_report.py --loops-root /srv/automation-mvp/data/research_loops --since-days 30 --output-md /srv/automation-mvp/data/reports/meta_search_report_latest.md --output-json /srv/automation-mvp/data/reports/meta_search_report_latest.json
