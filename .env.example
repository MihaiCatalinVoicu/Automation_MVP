WORKER_POLL_INTERVAL_SECONDS=2

REPO_CONFIG_PATH=./repos.json
CURSOR_AGENT_BIN=agent
CURSOR_TIMEOUT_SECONDS=1800
CURSOR_FORCE_EXECUTOR=true
CURSOR_TRUST_WORKSPACE=true
CURSOR_APPROVE_MCPS=false
CURSOR_CLOUD_MODE=false
CURSOR_SANDBOX=
CURSOR_COMPOSER_MODEL=
CURSOR_PREMIUM_MODEL=
