APP_HOST=0.0.0.0
APP_PORT=8000
DB_PATH=./data/orchestrator.db

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me
TELEGRAM_ALLOWED_USER_ID=replace_me
TELEGRAM_POLL_INTERVAL_SECONDS=2

DEFAULT_EXECUTOR_AGENT=composer
PREMIUM_PLANNER_AGENT=premium
PREMIUM_REVIEWER_AGENT=premium
REPEAT_FAILURE_THRESHOLD=3
